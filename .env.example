# Required for Telegram/Railway deployment
BOT_TOKEN=
ADMIN_IDS=123456789,987654321
ANNOUNCEMENT_CHANNEL_ID=-1003846885691
DISCUSSION_GROUP_ID=-1003994249946
ADMIN_LOG_CHANNEL_ID=-1005555555555

# Giveaway behavior
LOW_STOCK_ALERT_AMOUNT=25
CLAIM_CODE_PREFIX=CPM
CLAIM_CODE_LENGTH=6

# Railway persistent storage
RAILWAY_VOLUME_MOUNT_PATH=/data
# Optional override. If omitted, the app uses $RAILWAY_VOLUME_MOUNT_PATH/giveaways.db
# DATABASE_PATH=/data/giveaways.db

# Maintenance
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
RESERVED_ACCOUNT_TIMEOUT_HOURS=24
LOG_LEVEL=INFO
